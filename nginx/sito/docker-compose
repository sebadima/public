version: '3'

services:
  www:
    image: nginx:latest
    expose:
       - 80
    restart: always
    volumes:
       - /mnt/www/sito:/usr/share/nginx/html
       - ./nginx_custom.conf:/etc/nginx/conf.d/default.conf:ro
    environment:
        VIRTUAL_HOST     : ${DOMAIN}
        LETSENCRYPT_HOST : ${DOMAIN}
        LETSENCRYPT_EMAIL: ${EMAIL}
    container_name: ${CONTAINER_NAME}

networks:
  default:
    external:
      name: ${NETWORK}
